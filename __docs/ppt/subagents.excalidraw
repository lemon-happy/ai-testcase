    {
      "id": "ApMx9cka4TT7kA5TzHhEd",
      "type": "text",
      "x": 734.9562721664702,
      "y": 3053.432670903315,
      "width": 796.7999877929688,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0D",
      "roundness": null,
      "seed": 837647867,
      "version": 214,
      "versionNonce": 2092791253,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777100659884,
      "link": null,
      "locked": false,
      "text": "子代理机制将复杂任务“模块化”，通过隔离上下文、强化专业性、限制权限和开启并行，极\n大地提升了 Claude Code 处理复杂软件工程问题的效率和准确度。",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "子代理机制将复杂任务“模块化”，通过隔离上下文、强化专业性、限制权限和开启并行，极大地提升了 Claude Code 处理复杂软件工程问题的效率和准确度。",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "WNcLeT569SMpjflboFGiK",
      "type": "text",
      "x": 1016.8017983469842,
      "y": 2601.999672453072,
      "width": 516.7999877929688,
      "height": 50,
      "angle": 0,
      "strokeColor": "#f08c00",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0E",
      "roundness": null,
      "seed": 1882075989,
      "version": 102,
      "versionNonce": 602116411,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777100657568,
      "link": null,
      "locked": false,
      "text": "每个子代理拥有独立的上下文\n子代理处理具体任务时，主代理的上下文窗口能保持“干净”",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "每个子代理拥有独立的上下文\n子代理处理具体任务时，主代理的上下文窗口能保持“干净”",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "mCZKWi2ypmVjNblpyL7pl",
      "type": "text",
      "x": 1021.9730001285145,
      "y": 2716.3439392836704,
      "width": 365.97599443037313,
      "height": 50,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0F",
      "roundness": null,
      "seed": 754343957,
      "version": 136,
      "versionNonce": 260290709,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777100704128,
      "link": null,
      "locked": false,
      "text": "为不同的子代理设定更专注的系统提示词\n术业有专攻",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "为不同的子代理设定更专注的系统提示词\n术业有专攻",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "Hr_UHlHCCWR2U6-_LP2rz",
      "type": "text",
      "x": 1020.901547160566,
      "y": 2838.638331707478,
      "width": 260,
      "height": 50,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0G",
      "roundness": null,
      "seed": 974970485,
      "version": 118,
      "versionNonce": 1310125301,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777100702595,
      "link": null,
      "locked": false,
      "text": "明确限制子代理的能力\n通过限制工具集明确安全边界",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "明确限制子代理的能力\n通过限制工具集明确安全边界",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "rqJ5yx_gMC7-iHy9JY6-f",
      "type": "text",
      "x": 1019.9232703955915,
      "y": 2956.8424363292575,
      "width": 300,
      "height": 50,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0H",
      "roundness": null,
      "seed": 1854551035,
      "version": 112,
      "versionNonce": 1921070645,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1777100701562,
      "link": null,
      "locked": false,
      "text": "多个子代理可以同时独立执行任务\n适合处理复杂工作流",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "多个子代理可以同时独立执行任务\n适合处理复杂工作流",
      "autoResize": true,
      "lineHeight": 1.25
    }
